POSTGRES_USER=quiz
POSTGRES_PASSWORD=change_me
POSTGRES_DB=quiz
POSTGRES_PORT=5432
BACKEND_PORT=8080
FRONTEND_PORT=3000
PUBLIC_API_BASE_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:3000
SEED_DEMO_DATA=true
# Set all three values once to create the first administrator on backend startup.
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
OIDC_ISSUER=http://localhost:8080
OIDC_ALLOW_EPHEMERAL_CREDENTIALS=true
# Docker Compose serves the local backend over HTTP. Keep this true in production.
OIDC_REQUIRE_HTTPS=false
# Railway requires stable secrets instead of ephemeral credentials.
OIDC_SIGNING_CERTIFICATE_BASE64=
OIDC_SIGNING_CERTIFICATE_PASSWORD=
OIDC_ENCRYPTION_KEY_BASE64=
